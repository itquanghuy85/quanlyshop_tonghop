rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ============================================================
    // PRODUCTION SECURITY RULES - Quản Lý Shop (HULUCA)
    // Version: 4.0 | Date: 2026-01-10
    // Author: Firebase Security Architect
    // ============================================================
    // 
    // CUSTOM CLAIMS (set by Cloud Functions):
    // - shopId: string (user's assigned shop)
    // - role: string (owner|manager|employee|technician|user)
    // - isSuperAdmin: boolean (true for admin@huluca.com)
    //
    // SECURITY PRINCIPLES:
    // 1. All read/write require authentication
    // 2. Multi-tenant isolation via shopId from Custom Claims
    // 3. Role-based access control (owner > manager > employee > technician)
    // 4. Schema validation on all writes
    // 5. Protected fields: role, shopId, isAdmin, balance, ownerUid
    // 6. Soft deletes only (allow delete: if false)
    // 7. Super Admin bypasses all restrictions
    // ============================================================

    // ==================== BLOCK 1: AUTHENTICATION ====================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function currentUserId() {
      return request.auth.uid;
    }

    // ==================== BLOCK 2: SUPER ADMIN ====================
    // Uses isSuperAdmin claim set by Cloud Function
    
    function isSuperAdmin() {
      return isAuthenticated() && 
             request.auth.token.isSuperAdmin == true;
    }

    // ==================== BLOCK 3: MULTI-TENANT ISOLATION ====================
    // All data access is restricted to user's shopId from Custom Claims
    
    // Get shopId from Custom Claims (PRIMARY - no Firestore read)
    function getShopId() {
      return request.auth.token.shopId;
    }
    
    // Check if user belongs to a specific shop
    function belongsToShop(shopId) {
      return isSuperAdmin() || getShopId() == shopId;
    }
    
    // Check if EXISTING document belongs to user's shop
    function docInUserShop() {
      return isSuperAdmin() || 
             ('shopId' in resource.data && resource.data.shopId == getShopId());
    }
    
    // Check if INCOMING data has correct shopId
    function incomingShopIdValid() {
      return isSuperAdmin() || 
             request.resource.data.shopId == getShopId();
    }

    // ==================== BLOCK 4: ROLE-BASED ACCESS ====================
    // Hierarchy: admin(super) > owner > manager > employee > technician > user
    
    // Get role from Custom Claims (PRIMARY - no Firestore read)
    function getRole() {
      return request.auth.token.role;
    }
    
    function isOwner() {
      return isSuperAdmin() || getRole() == 'owner';
    }
    
    function isManagerOrAbove() {
      return isOwner() || getRole() == 'manager';
    }
    
    function isEmployeeOrAbove() {
      return isManagerOrAbove() || getRole() == 'employee';
    }
    
    function isTechnicianOrAbove() {
      return isManagerOrAbove() || getRole() == 'technician';
    }
    
    function isAnyStaff() {
      return isEmployeeOrAbove() || isTechnicianOrAbove();
    }

    // ==================== BLOCK 5: PROTECTED FIELDS ====================
    // These fields can ONLY be modified by Cloud Functions
    
    function fieldChanged(field) {
      return field in resource.data && 
             field in request.resource.data &&
             request.resource.data[field] != resource.data[field];
    }
    
    // CRITICAL: Block client from changing role or shopId
    function protectedFieldsUnchanged() {
      return isSuperAdmin() || (
        !fieldChanged('role') &&
        !fieldChanged('shopId') &&
        !fieldChanged('isAdmin') &&
        !fieldChanged('isSuperAdmin') &&
        !fieldChanged('balance') &&
        !fieldChanged('ownerUid') &&
        !fieldChanged('claimsSyncedAt') &&
        !fieldChanged('_claimsVersion')
      );
    }
    
    // For create: block setting protected fields
    function noProtectedFieldsOnCreate() {
      return isSuperAdmin() || (
        !('isAdmin' in request.resource.data) &&
        !('isSuperAdmin' in request.resource.data) &&
        !('balance' in request.resource.data)
      );
    }

    // ==================== BLOCK 6: SCHEMA VALIDATION ====================
    
    function hasFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }
    
    function isString(field, minLen, maxLen) {
      return field in request.resource.data &&
             request.resource.data[field] is string &&
             request.resource.data[field].size() >= minLen &&
             request.resource.data[field].size() <= maxLen;
    }
    
    function isOptionalString(field) {
      return !(field in request.resource.data) ||
             request.resource.data[field] == null ||
             request.resource.data[field] is string;
    }
    
    function isInt(field) {
      return field in request.resource.data &&
             request.resource.data[field] is int;
    }
    
    function isNonNegativeInt(field) {
      return field in request.resource.data &&
             request.resource.data[field] is int &&
             request.resource.data[field] >= 0;
    }
    
    function isOptionalInt(field) {
      return !(field in request.resource.data) ||
             request.resource.data[field] == null ||
             request.resource.data[field] is int;
    }
    
    function isOptionalNonNegativeInt(field) {
      return !(field in request.resource.data) ||
             request.resource.data[field] == null ||
             (request.resource.data[field] is int && request.resource.data[field] >= 0);
    }
    
    function isBool(field) {
      return field in request.resource.data &&
             request.resource.data[field] is bool;
    }
    
    function isOptionalBool(field) {
      return !(field in request.resource.data) ||
             request.resource.data[field] == null ||
             request.resource.data[field] is bool;
    }
    
    function isValidStatus(field, min, max) {
      return field in request.resource.data &&
             request.resource.data[field] is int &&
             request.resource.data[field] >= min &&
             request.resource.data[field] <= max;
    }

    // ==================== COLLECTION: users ====================
    match /users/{userId} {
      // READ: Any authenticated user can read profiles (for collaboration)
      allow read: if isAuthenticated();
      
      // CREATE: User can only create their own profile
      allow create: if isAuthenticated() && 
                       currentUserId() == userId &&
                       hasFields(['email']) &&
                       noProtectedFieldsOnCreate() &&
                       // Cannot self-assign privileged role
                       (!('role' in request.resource.data) || 
                        request.resource.data.role in ['user', 'employee', 'technician']);
      
      // UPDATE: Own profile OR manager in same shop
      allow update: if isAuthenticated() &&
                       (currentUserId() == userId || 
                        isSuperAdmin() || 
                        (isManagerOrAbove() && belongsToShop(resource.data.shopId))) &&
                       // CRITICAL: Protected fields check
                       protectedFieldsUnchanged();
      
      // DELETE: Soft delete only (set deleted: true)
      allow delete: if false;
    }

    // ==================== COLLECTION: shops ====================
    match /shops/{shopId} {
      // READ: Only shop members
      allow read: if isAuthenticated() && belongsToShop(shopId);
      
      // CREATE: Any authenticated user can create shop (becomes owner)
      allow create: if isAuthenticated() &&
                       hasFields(['ownerUid', 'name']) &&
                       request.resource.data.ownerUid == currentUserId() &&
                       isString('name', 1, 100);
      
      // UPDATE: Only owner of the shop
      allow update: if isAuthenticated() && 
                       (isSuperAdmin() || resource.data.ownerUid == currentUserId()) &&
                       !fieldChanged('ownerUid');
      
      // DELETE: Never (soft delete)
      allow delete: if false;
    }

    // ==================== COLLECTION: repairs ====================
    match /repairs/{repairId} {
      // READ: Shop members only
      allow read: if isAuthenticated() && docInUserShop();
      
      // CREATE: Any staff can create
      allow create: if isAuthenticated() &&
                       isAnyStaff() &&
                       incomingShopIdValid() &&
                       hasFields(['customerName', 'phone', 'model', 'issue', 'createdAt', 'status', 'shopId']) &&
                       isString('customerName', 1, 100) &&
                       isString('model', 1, 100) &&
                       isValidStatus('status', 1, 4) &&
                       isOptionalNonNegativeInt('price') &&
                       isOptionalNonNegativeInt('cost');
      
      // UPDATE: Shop members, cannot change shopId
      allow update: if isAuthenticated() && 
                       docInUserShop() &&
                       !fieldChanged('shopId') &&
                       isValidStatus('status', 1, 4) &&
                       isOptionalNonNegativeInt('price') &&
                       isOptionalNonNegativeInt('cost');
      
      // DELETE: Soft delete only
      allow delete: if false;
    }

    // ==================== COLLECTION: sales ====================
    match /sales/{saleId} {
      allow read: if isAuthenticated() && docInUserShop();
      
      allow create: if isAuthenticated() && 
                       isEmployeeOrAbove() &&
                       incomingShopIdValid() &&
                       hasFields(['customerName', 'productNames', 'totalPrice', 'soldAt', 'shopId']) &&
                       isString('customerName', 1, 100) &&
                       isNonNegativeInt('totalPrice') &&
                       isOptionalNonNegativeInt('totalCost');
      
      allow update: if isAuthenticated() && 
                       docInUserShop() &&
                       !fieldChanged('shopId') &&
                       isNonNegativeInt('totalPrice') &&
                       isOptionalNonNegativeInt('totalCost');
      
      allow delete: if false;
    }

    // ==================== COLLECTION: products ====================
    match /products/{productId} {
      allow read: if isAuthenticated() && docInUserShop();
      
      allow create: if isAuthenticated() && 
                       isEmployeeOrAbove() &&
                       incomingShopIdValid() &&
                       hasFields(['name', 'shopId']) &&
                       isString('name', 1, 200) &&
                       isOptionalNonNegativeInt('cost') &&
                       isOptionalNonNegativeInt('price') &&
                       isOptionalNonNegativeInt('quantity');
      
      allow update: if isAuthenticated() && 
                       docInUserShop() &&
                       !fieldChanged('shopId') &&
                       isOptionalNonNegativeInt('cost') &&
                       isOptionalNonNegativeInt('price') &&
                       isOptionalNonNegativeInt('quantity');
      
      allow delete: if false;
    }

    // ==================== COLLECTION: expenses ====================
    // Financial data - Manager+ only
    match /expenses/{expenseId} {
      allow read: if isAuthenticated() && docInUserShop() && isManagerOrAbove();
      
      allow create: if isAuthenticated() && 
                       isManagerOrAbove() &&
                       incomingShopIdValid() &&
                       hasFields(['title', 'amount', 'category', 'date', 'shopId']) &&
                       isString('title', 1, 200) &&
                       isNonNegativeInt('amount');
      
      allow update: if isAuthenticated() && 
                       docInUserShop() &&
                       isManagerOrAbove() &&
                       !fieldChanged('shopId') &&
                       isNonNegativeInt('amount');
      
      allow delete: if false;
    }

    // ==================== COLLECTION: attendance ====================
    match /attendance/{attendanceId} {
      // READ: Own records or manager sees all
      allow read: if isAuthenticated() && 
                     docInUserShop() &&
                     (isManagerOrAbove() || resource.data.userId == currentUserId());
      
      // CREATE: Own attendance or manager
      allow create: if isAuthenticated() && 
                       incomingShopIdValid() &&
                       hasFields(['userId', 'dateKey', 'createdAt', 'shopId']) &&
                       (isManagerOrAbove() || request.resource.data.userId == currentUserId());
      
      // UPDATE: Own (limited) or manager (full)
      allow update: if isAuthenticated() && 
                       docInUserShop() &&
                       !fieldChanged('shopId') &&
                       (isManagerOrAbove() || 
                        (resource.data.userId == currentUserId() &&
                         !fieldChanged('status') && 
                         !fieldChanged('locked') && 
                         !fieldChanged('approvedBy')));
      
      allow delete: if false;
    }

    // ==================== COLLECTION: debts ====================
    // Financial - Manager+ only
    match /debts/{debtId} {
      allow read: if isAuthenticated() && docInUserShop() && isManagerOrAbove();
      
      allow create: if isAuthenticated() && 
                       isManagerOrAbove() &&
                       incomingShopIdValid() &&
                       hasFields(['personName', 'totalAmount', 'type', 'createdAt', 'shopId']) &&
                       isNonNegativeInt('totalAmount') &&
                       isOptionalNonNegativeInt('paidAmount');
      
      allow update: if isAuthenticated() && 
                       docInUserShop() &&
                       isManagerOrAbove() &&
                       !fieldChanged('shopId') &&
                       isNonNegativeInt('totalAmount') &&
                       isOptionalNonNegativeInt('paidAmount');
      
      allow delete: if false;
    }

    // ==================== COLLECTION: debt_payments ====================
    match /debt_payments/{paymentId} {
      allow read: if isAuthenticated() && docInUserShop() && isManagerOrAbove();
      
      allow create: if isAuthenticated() && 
                       isManagerOrAbove() &&
                       incomingShopIdValid() &&
                       hasFields(['debtId', 'amount', 'paidAt', 'shopId']) &&
                       isNonNegativeInt('amount');
      
      allow update: if isAuthenticated() && 
                       docInUserShop() &&
                       isManagerOrAbove() &&
                       !fieldChanged('shopId') &&
                       isNonNegativeInt('amount');
      
      allow delete: if false;
    }

    // ==================== COLLECTION: suppliers ====================
    match /suppliers/{supplierId} {
      allow read: if isAuthenticated() && docInUserShop();
      
      allow create: if isAuthenticated() && 
                       isEmployeeOrAbove() &&
                       incomingShopIdValid() &&
                       hasFields(['name', 'shopId']) &&
                       isString('name', 1, 200);
      
      allow update: if isAuthenticated() && 
                       docInUserShop() &&
                       !fieldChanged('shopId');
      
      allow delete: if false;
    }

    // ==================== COLLECTION: supplier_payments ====================
    match /supplier_payments/{paymentId} {
      allow read: if isAuthenticated() && docInUserShop() && isManagerOrAbove();
      
      allow create: if isAuthenticated() && 
                       isManagerOrAbove() &&
                       incomingShopIdValid() &&
                       hasFields(['supplierId', 'amount', 'paidAt', 'shopId']) &&
                       isNonNegativeInt('amount');
      
      allow update: if isAuthenticated() && 
                       docInUserShop() &&
                       isManagerOrAbove() &&
                       !fieldChanged('shopId') &&
                       isNonNegativeInt('amount');
      
      allow delete: if false;
    }

    // ==================== COLLECTION: customers ====================
    match /customers/{customerId} {
      allow read: if isAuthenticated() && docInUserShop();
      
      allow create: if isAuthenticated() && 
                       incomingShopIdValid() &&
                       hasFields(['name', 'shopId']) &&
                       isString('name', 1, 100);
      
      allow update: if isAuthenticated() && 
                       docInUserShop() &&
                       !fieldChanged('shopId');
      
      allow delete: if false;
    }

    // ==================== COLLECTION: repair_partners ====================
    match /repair_partners/{partnerId} {
      allow read: if isAuthenticated() && docInUserShop();
      
      allow create: if isAuthenticated() && 
                       isEmployeeOrAbove() &&
                       incomingShopIdValid() &&
                       hasFields(['name', 'shopId']) &&
                       isString('name', 1, 200);
      
      allow update: if isAuthenticated() && 
                       docInUserShop() &&
                       !fieldChanged('shopId');
      
      allow delete: if false;
    }

    // ==================== COLLECTION: repair_partner_payments ====================
    match /repair_partner_payments/{paymentId} {
      allow read: if isAuthenticated() && docInUserShop() && isManagerOrAbove();
      
      allow create: if isAuthenticated() && 
                       isManagerOrAbove() &&
                       incomingShopIdValid() &&
                       hasFields(['partnerId', 'amount', 'paidAt', 'shopId']) &&
                       isNonNegativeInt('amount');
      
      allow update: if isAuthenticated() && 
                       docInUserShop() &&
                       isManagerOrAbove() &&
                       !fieldChanged('shopId') &&
                       isNonNegativeInt('amount');
      
      allow delete: if false;
    }

    // ==================== COLLECTION: partner_repair_history ====================
    match /partner_repair_history/{historyId} {
      allow read: if isAuthenticated() && docInUserShop();
      
      allow create: if isAuthenticated() && 
                       isEmployeeOrAbove() &&
                       incomingShopIdValid() &&
                       hasFields(['partnerId', 'repairId', 'shopId']);
      
      allow update: if isAuthenticated() && 
                       docInUserShop() &&
                       !fieldChanged('shopId');
      
      allow delete: if false;
    }

    // ==================== COLLECTION: purchase_orders ====================
    match /purchase_orders/{orderId} {
      allow read: if isAuthenticated() && docInUserShop() && isManagerOrAbove();
      
      allow create: if isAuthenticated() && 
                       isManagerOrAbove() &&
                       incomingShopIdValid() &&
                       hasFields(['shopId']);
      
      allow update: if isAuthenticated() && 
                       docInUserShop() &&
                       isManagerOrAbove() &&
                       !fieldChanged('shopId');
      
      allow delete: if false;
    }

    // ==================== COLLECTION: quick_input_codes ====================
    match /quick_input_codes/{codeId} {
      allow read: if isAuthenticated() && docInUserShop();
      
      allow create: if isAuthenticated() && 
                       incomingShopIdValid() &&
                       hasFields(['code', 'shopId']);
      
      allow update: if isAuthenticated() && 
                       docInUserShop() &&
                       !fieldChanged('shopId');
      
      // This collection allows delete for cleanup
      allow delete: if isAuthenticated() && docInUserShop();
    }

    // ==================== COLLECTION: cash_closings ====================
    match /cash_closings/{closingId} {
      allow read: if isAuthenticated() && docInUserShop() && isManagerOrAbove();
      
      allow create: if isAuthenticated() && 
                       isManagerOrAbove() &&
                       incomingShopIdValid() &&
                       hasFields(['shopId', 'date']);
      
      allow update: if isAuthenticated() && 
                       docInUserShop() &&
                       isManagerOrAbove() &&
                       !fieldChanged('shopId');
      
      allow delete: if false;
    }

    // ==================== COLLECTION: audit_logs ====================
    // IMMUTABLE: Write-once, never modify or delete
    match /audit_logs/{logId} {
      allow read: if isAuthenticated() && docInUserShop() && isManagerOrAbove();
      
      allow create: if isAuthenticated() && 
                       incomingShopIdValid() &&
                       hasFields(['action', 'userId', 'createdAt', 'shopId']);
      
      // IMMUTABLE
      allow update: if false;
      allow delete: if false;
    }

    // ==================== COLLECTION: repair_parts ====================
    match /repair_parts/{partId} {
      allow read: if isAuthenticated() && docInUserShop();
      
      allow create: if isAuthenticated() && 
                       isEmployeeOrAbove() &&
                       incomingShopIdValid() &&
                       hasFields(['name', 'shopId']) &&
                       isString('name', 1, 200);
      
      allow update: if isAuthenticated() && 
                       docInUserShop() &&
                       !fieldChanged('shopId');
      
      allow delete: if false;
    }

    // ==================== COLLECTION: chats ====================
    match /chats/{chatId} {
      allow read: if isAuthenticated() && docInUserShop();
      
      allow create: if isAuthenticated() && 
                       incomingShopIdValid() &&
                       hasFields(['message', 'senderId', 'shopId']) &&
                       request.resource.data.senderId == currentUserId();
      
      allow update: if isAuthenticated() && docInUserShop();
      
      allow delete: if false;
    }

    // ==================== COLLECTION: notifications ====================
    match /notifications/{notificationId} {
      // READ: Shop notifications OR own notifications
      allow read: if isAuthenticated() && 
                     (docInUserShop() || 
                      resource.data.userId == currentUserId() ||
                      resource.data.userId == null);
      
      allow create: if isAuthenticated() && incomingShopIdValid();
      
      allow update: if isAuthenticated() && 
                       (docInUserShop() || resource.data.userId == currentUserId());
      
      allow delete: if false;
    }

    // ==================== COLLECTION: shop_notifications ====================
    match /shop_notifications/{notificationId} {
      allow read: if isAuthenticated() && docInUserShop();
      
      allow create: if isAuthenticated() && incomingShopIdValid();
      
      allow update: if isAuthenticated() && docInUserShop();
      
      allow delete: if isAuthenticated() && docInUserShop() && isManagerOrAbove();
    }

    // ==================== COLLECTION: invites ====================
    match /invites/{inviteCode} {
      // READ: Anyone authenticated (to validate invite)
      allow read: if isAuthenticated();
      
      // CREATE: Manager+ can create invites
      allow create: if isAuthenticated() && 
                       isManagerOrAbove() &&
                       hasFields(['shopId', 'role', 'createdBy']);
      
      // UPDATE: Only mark as used
      allow update: if isAuthenticated() && 
                       request.resource.data.diff(resource.data).affectedKeys()
                         .hasOnly(['used', 'usedBy', 'usedAt']);
      
      // DELETE: Owner only
      allow delete: if isAuthenticated() && isOwner();
    }

    // ==================== COLLECTION: supplier_import_history ====================
    match /supplier_import_history/{historyId} {
      allow read: if isAuthenticated() && docInUserShop();
      
      allow create: if isAuthenticated() && 
                       isEmployeeOrAbove() &&
                       incomingShopIdValid() &&
                       hasFields(['supplierId', 'shopId']);
      
      allow update: if isAuthenticated() && 
                       docInUserShop() &&
                       !fieldChanged('shopId');
      
      allow delete: if false;
    }

    // ==================== COLLECTION: supplier_product_prices ====================
    match /supplier_product_prices/{priceId} {
      allow read: if isAuthenticated() && docInUserShop();
      
      allow create: if isAuthenticated() && 
                       isEmployeeOrAbove() &&
                       incomingShopIdValid() &&
                       hasFields(['supplierId', 'productName', 'price', 'shopId']) &&
                       isNonNegativeInt('price');
      
      allow update: if isAuthenticated() && 
                       docInUserShop() &&
                       !fieldChanged('shopId') &&
                       isNonNegativeInt('price');
      
      allow delete: if isAuthenticated() && docInUserShop() && isManagerOrAbove();
    }

    // ==================== COLLECTION: chat_messages ====================
    match /chat_messages/{messageId} {
      allow read: if isAuthenticated() && docInUserShop();
      
      allow create: if isAuthenticated() && 
                       incomingShopIdValid() &&
                       hasFields(['message', 'senderId', 'shopId']);
      
      allow update: if isAuthenticated() && docInUserShop();
      
      allow delete: if false;
    }

    // ==================== CATCH-ALL: DENY ALL OTHER COLLECTIONS ====================
    // CRITICAL: Any collection not explicitly defined is DENIED
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
