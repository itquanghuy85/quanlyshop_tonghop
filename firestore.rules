rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ╔══════════════════════════════════════════════════════════════════╗
    // ║  PRODUCTION SECURITY RULES - Quản Lý Shop (HULUCA)               ║
    // ║  Version: 5.0 | Date: 2026-01-10                                 ║
    // ║  Author: Firebase Security Architect                             ║
    // ╠══════════════════════════════════════════════════════════════════╣
    // ║  CUSTOM CLAIMS (set by Cloud Functions only):                    ║
    // ║  • isSuperAdmin: boolean (true for admin@huluca.com)             ║
    // ║  • shopId: string (user's assigned shop)                         ║
    // ║  • role: owner | manager | employee | technician | user          ║
    // ╠══════════════════════════════════════════════════════════════════╣
    // ║  ROLE HIERARCHY: superAdmin > owner > manager > employee/tech    ║
    // ╠══════════════════════════════════════════════════════════════════╣
    // ║  COLLECTIONS BY GROUP:                                           ║
    // ║  [AUTH]     users, shops, invites                                ║
    // ║  [BUSINESS] repairs, sales, products, customers                  ║
    // ║  [FINANCE]  expenses, debts, debt_payments, cash_closings,       ║
    // ║              adjustment_entries                                  ║
    // ║  [SUPPLIER] suppliers, supplier_payments, purchase_orders        ║
    // ║  [PARTNER]  repair_partners, repair_partner_payments             ║
    // ║  [HR]       attendance, leave_requests, shift_swap_requests,      ║
    // ║              work_schedules                                       ║
    // ║  [CHAT]     chats, chat_messages                                 ║
    // ║  [NOTIFY]   notifications, shop_notifications                    ║
    // ║  [SYSTEM]   audit_logs, quick_input_codes, repair_parts          ║
    // ╚══════════════════════════════════════════════════════════════════╝

    // ┌──────────────────────────────────────────────────────────────────┐
    // │                    SECTION 1: CORE FUNCTIONS                     │
    // └──────────────────────────────────────────────────────────────────┘

    // ═══════════ 1.1 AUTHENTICATION ═══════════
    function isAuth() {
      return request.auth != null;
    }
    
    function uid() {
      return request.auth.uid;
    }

    // ═══════════ 1.2 SUPER ADMIN (from isSuperAdmin claim OR email fallback) ═══════════
    function isSuperAdmin() {
      return isAuth() && (
        request.auth.token.isSuperAdmin == true ||
        request.auth.token.email == 'admin@huluca.com'
      );
    }

    // ═══════════ 1.3 MULTI-TENANT ISOLATION ═══════════
    // Ưu tiên user document vì claims có thể bị stale ngắn hạn sau đổi shop/role.
    // claims vẫn được dùng fallback khi user doc chưa sẵn sàng.
    function myUserShopId() {
      return isAuth() &&
             exists(/databases/$(database)/documents/users/$(uid()))
             ? get(/databases/$(database)/documents/users/$(uid())).data.shopId
             : null;
    }

    function myShopId() {
      return myUserShopId() != null
             ? myUserShopId()
             : request.auth.token.shopId;
    }
    
    // Check if user owns a specific shop (for multi-shop owners)
    // Also checks that shop exists and is not deleted
    function isShopOwner(shopId) {
      return exists(/databases/$(database)/documents/shops/$(shopId)) &&
             get(/databases/$(database)/documents/shops/$(shopId)).data.ownerUid == uid() &&
             get(/databases/$(database)/documents/shops/$(shopId)).data.deleted != true;
    }
    
    // Check if user owns a shop regardless of deleted state
    // Used for cleanup operations (deleting data from a deleted shop)
    function isShopOwnerAnyState(shopId) {
      return exists(/databases/$(database)/documents/shops/$(shopId)) &&
             get(/databases/$(database)/documents/shops/$(shopId)).data.ownerUid == uid();
    }
    
    // Check if shop exists and is active (not deleted)
    function shopExistsAndActive(shopId) {
      return exists(/databases/$(database)/documents/shops/$(shopId)) &&
             get(/databases/$(database)/documents/shops/$(shopId)).data.deleted != true;
    }
    
    function belongsTo(shopId) {
      // Allow if: super admin, user owns this shop, OR claims match
      // isShopOwner first to short-circuit before myShopId() which can fail
      return isSuperAdmin() || 
             isShopOwner(shopId) ||
             (shopExistsAndActive(shopId) && myShopId() == shopId);
    }
    
    function docInMyShop() {
      return isSuperAdmin() || 
             ('shopId' in resource.data && (
               resource.data.shopId == myShopId() || 
               isShopOwner(resource.data.shopId)
             ));
    }
    
    // Cho phép owner xóa data kể cả khi shop đã bị soft-delete
    function docInMyShopForDelete() {
      return isSuperAdmin() || 
             ('shopId' in resource.data && (
               resource.data.shopId == myShopId() || 
               isShopOwnerAnyState(resource.data.shopId)
             ));
    }
    
    function newDocInMyShop() {
      return isSuperAdmin() || 
             request.resource.data.shopId == myShopId() ||
             isShopOwner(request.resource.data.shopId);
    }

    // ═══════════ 1.4 ROLE-BASED ACCESS ═══════════
    function myUserRole() {
      return isAuth() &&
             exists(/databases/$(database)/documents/users/$(uid()))
             ? get(/databases/$(database)/documents/users/$(uid())).data.role
             : null;
    }

    function myRole() {
      return myUserRole() != null
             ? myUserRole()
             : request.auth.token.role;
    }
    
    function isOwner() {
      return isSuperAdmin() || myRole() == 'owner';
    }
    
    function isManager() {
      return isOwner() || myRole() == 'manager';
    }
    
    function isEmployee() {
      return isManager() || myRole() == 'employee';
    }
    
    function isTechnician() {
      return isManager() || myRole() == 'technician';
    }
    
    function isStaff() {
      return isEmployee() || isTechnician();
    }

    function hasUserPermission(flag) {
      return isAuth() &&
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data[flag] == true;
    }

    function canCreateSales() {
      return isEmployee() || hasUserPermission('allowViewSales');
    }

    // ═══════════ 1.5 PROTECTED FIELDS ═══════════
    // Client CANNOT modify these - Cloud Functions only
    function changed(field) {
      return field in resource.data && 
             field in request.resource.data &&
             request.resource.data[field] != resource.data[field];
    }
    
    // Protected fields - nhưng owner có thể thay đổi role và shopId của nhân viên trong shop
    function protectedOK() {
      return isSuperAdmin() || (
        // shopId: owner có thể gán/đổi shopId cho nhân viên
        (!changed('shopId') || isOwner()) &&
        !changed('isAdmin') &&
        !changed('isSuperAdmin') &&
        !changed('balance') &&
        !changed('ownerUid') &&
        !changed('claimsSyncedAt')
      );
    }
    
    // Kiểm tra role change hợp lệ - owner có thể thay đổi role của người khác trong shop
    function roleChangeOK() {
      return isSuperAdmin() || 
             !changed('role') ||
             (isOwner() && 'shopId' in resource.data && belongsTo(resource.data.shopId)) ||
             // Fallback: Check if current user is the shop owner directly
             ('shopId' in resource.data && 
              exists(/databases/$(database)/documents/shops/$(resource.data.shopId)) &&
              get(/databases/$(database)/documents/shops/$(resource.data.shopId)).data.ownerUid == uid());
    }
    
    function shopIdLocked() {
      return isSuperAdmin() || !changed('shopId');
    }

    // ═══════════ 1.6 SCHEMA VALIDATION ═══════════
    function has(fields) {
      return request.resource.data.keys().hasAll(fields);
    }
    
    function str(f, min, max) {
      return f in request.resource.data &&
             request.resource.data[f] is string &&
             request.resource.data[f].size() >= min &&
             request.resource.data[f].size() <= max;
    }
    
    function optStr(f) {
      return !(f in request.resource.data) ||
             request.resource.data[f] == null ||
             request.resource.data[f] is string;
    }
    
    function num(f) {
      return f in request.resource.data && request.resource.data[f] is number;
    }
    
    function numGte0(f) {
      return f in request.resource.data &&
             request.resource.data[f] is number &&
             request.resource.data[f] >= 0;
    }
    
    function optNum(f) {
      return !(f in request.resource.data) ||
             request.resource.data[f] == null ||
             request.resource.data[f] is number;
    }
    
    function optNumGte0(f) {
      return !(f in request.resource.data) ||
             request.resource.data[f] == null ||
             (request.resource.data[f] is number && request.resource.data[f] >= 0);
    }
    
    function status(f, min, max) {
      return f in request.resource.data &&
             request.resource.data[f] is number &&
             request.resource.data[f] >= min &&
             request.resource.data[f] <= max;
    }

    // ┌──────────────────────────────────────────────────────────────────┐
    // │              SECTION 2: AUTH & USER MANAGEMENT                   │
    // │              Collections: users, shops, invites                  │
    // └──────────────────────────────────────────────────────────────────┘

    // ═══════════ 2.1 USERS ═══════════
    match /users/{userId} {
      // READ: Any authenticated user (for collaboration features)
      allow read: if isAuth();
      
      // CREATE: Own profile only, cannot self-assign admin roles
      // Allow 'owner' role ONLY when user creates their own profile (new signup)
      allow create: if isAuth() && 
                       uid() == userId &&
                       has(['email']) &&
                       (!('role' in request.resource.data) || 
                        request.resource.data.role in ['user', 'employee', 'technician', 'owner']);
      
      // UPDATE: Own profile OR manager/owner of same shop
      // Owner can change role of staff in their shop
      // Also allow if current user owns the shop that the target user belongs to
      allow update: if isAuth() &&
                       (uid() == userId || 
                        isSuperAdmin() || 
                        (isManager() && belongsTo(resource.data.shopId)) ||
                        // Fallback: Check if current user is the shop owner directly
                        ('shopId' in resource.data && 
                         exists(/databases/$(database)/documents/shops/$(resource.data.shopId)) &&
                         get(/databases/$(database)/documents/shops/$(resource.data.shopId)).data.ownerUid == uid())
                       ) &&
                       protectedOK() &&
                       roleChangeOK();
      
      // DELETE: Soft delete only
      allow delete: if false;
    }

    // ═══════════ 2.2 SHOPS ═══════════
    match /shops/{shopId} {
      // READ: Shop members only
      // Also allow owner to read their own shop (before claims are synced)
      // Fallback: direct user doc check bypasses stale token claims
      allow read: if isAuth() && (
        belongsTo(shopId) || 
        resource.data.ownerUid == uid() ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.shopId == shopId
      );
      
      // CREATE: Any user can create shop (becomes owner)
      allow create: if isAuth() &&
                       has(['ownerUid', 'name']) &&
                       request.resource.data.ownerUid == uid() &&
                       str('name', 1, 100);
      
      // UPDATE: Shop owner only
      allow update: if isAuth() && 
                       (isSuperAdmin() || resource.data.ownerUid == uid()) &&
                       !changed('ownerUid');
      
      // DELETE: Owner or super admin only
      // Client MUST cancel all subscriptions before deleting
      // to avoid PERMISSION_DENIED errors on active listeners
      allow delete: if isAuth() && 
                       (isSuperAdmin() || resource.data.ownerUid == uid());

      // ─────────── SUBCOLLECTION: custom_salary_adjustments ───────────
      // Stores custom bonuses/deductions per employee per month
      match /custom_salary_adjustments/{adjustmentId} {
        // READ: Owner+ in same shop
        allow read: if isAuth() && belongsTo(shopId) && isOwner();
        
        // CREATE: Owner only (adding custom adjustments)
        allow create: if isAuth() && 
                         belongsTo(shopId) && 
                         isOwner() &&
                         has(['staffId', 'amount', 'name']);
        
        // UPDATE: Owner only
        allow update: if isAuth() && 
                         belongsTo(shopId) && 
                         isOwner();
        
        // DELETE: Owner only (remove adjustments, also during shop cleanup)
        allow delete: if isAuth() && (belongsTo(shopId) || isShopOwnerAnyState(shopId)) && isOwner();
      }

      // ─────────── SUBCOLLECTION: settings (Multi-industry) ───────────
      // Stores shop settings including businessType and module flags
      match /settings/{settingId} {
        // READ: Any shop member
        allow read: if isAuth() && belongsTo(shopId);
        
        // WRITE: Shop owner can always create/update settings (even before claims refresh)
        // Also allow any owner-role user who belongs to this shop
        allow create, update: if isAuth() && 
                         (isShopOwner(shopId) || 
                          (belongsTo(shopId) && isOwner()));
        
        // DELETE: Owner only (during shop deletion cleanup)
        allow delete: if isAuth() && isShopOwnerAnyState(shopId) && isOwner();
      }

      // ─────────── SUBCOLLECTION: product_categories (Multi-industry) ───────────
      // Dynamic product categories per shop
      match /product_categories/{categoryId} {
        // READ: Any shop member
        allow read: if isAuth() && belongsTo(shopId);
        
        // CREATE: Manager+ only
        allow create: if isAuth() && 
                         belongsTo(shopId) && 
                         isManager() &&
                         has(['name', 'shopId']);
        
        // UPDATE: Manager+ only
        allow update: if isAuth() && 
                         belongsTo(shopId) && 
                         isManager();
        
        // DELETE: Owner only (soft delete preferred, also during shop cleanup)
        allow delete: if isAuth() && (belongsTo(shopId) || isShopOwnerAnyState(shopId)) && isOwner();
      }
    }

    // ═══════════ 2.3 INVITES ═══════════
    match /invites/{inviteCode} {
      // READ: Any authenticated (to validate invite code)
      allow read: if isAuth();
      
      // CREATE: Manager+ only
      allow create: if isAuth() && 
                       isManager() &&
                       has(['shopId', 'role', 'createdBy']);
      
      // UPDATE: Only mark as used
      allow update: if isAuth() && 
                       request.resource.data.diff(resource.data).affectedKeys()
                         .hasOnly(['used', 'usedBy', 'usedAt']);
      
      // DELETE: Owner only
      allow delete: if isAuth() && isOwner();
    }

    // ┌──────────────────────────────────────────────────────────────────┐
    // │                SECTION 3: CORE BUSINESS                          │
    // │         Collections: repairs, sales, products, customers         │
    // └──────────────────────────────────────────────────────────────────┘

    // ═══════════ 3.1 REPAIRS ═══════════
    // Note: Allow all authenticated shop members to create repairs (basic function)
    // Previously required isStaff() but this blocked users with 'user' role
    match /repairs/{repairId} {
      allow read: if isAuth() && docInMyShop();
      
      allow create: if isAuth() &&
                       newDocInMyShop() &&
                       has(['customerName', 'phone', 'model', 'issue', 'createdAt', 'status', 'shopId']) &&
                       str('customerName', 1, 100) &&
                       str('model', 1, 100) &&
                       status('status', 1, 4) &&
                       optNumGte0('price') &&
                       optNumGte0('cost');
      
      allow update: if isAuth() && 
                       docInMyShop() &&
                       shopIdLocked() &&
                       status('status', 1, 4) &&
                       optNumGte0('price') &&
                       optNumGte0('cost');
      
      // DELETE: Owner/super admin only (for shop deletion cleanup)
      allow delete: if isAuth() && docInMyShopForDelete() && isOwner();
    }

    // ═══════════ 3.2 SALES ═══════════
    match /sales/{saleId} {
      allow read: if isAuth() && docInMyShop();
      
      allow create: if isAuth() && 
                       canCreateSales() &&
                       newDocInMyShop() &&
                       has(['customerName', 'productNames', 'totalPrice', 'soldAt', 'shopId']) &&
                       str('customerName', 1, 100) &&
                       numGte0('totalPrice') &&
                       optNumGte0('totalCost');
      
      allow update: if isAuth() && 
                       docInMyShop() &&
                       shopIdLocked() &&
                       numGte0('totalPrice') &&
                       optNumGte0('totalCost');
      
      // DELETE: Owner/super admin only (for shop deletion cleanup)
      allow delete: if isAuth() && docInMyShopForDelete() && isOwner();
    }

    // ═══════════ 3.3 PRODUCTS ═══════════
    match /products/{productId} {
      allow read: if isAuth() && docInMyShop();
      
      allow create: if isAuth() && 
                       isEmployee() &&
                       newDocInMyShop() &&
                       has(['name', 'shopId']) &&
                       str('name', 1, 200) &&
                       optNumGte0('cost') &&
                       optNumGte0('price') &&
                       optNumGte0('quantity');
      
      allow update: if isAuth() && 
                       docInMyShop() &&
                       shopIdLocked() &&
                       optNumGte0('cost') &&
                       optNumGte0('price') &&
                       optNumGte0('quantity');
      
      // DELETE: Owner/super admin only (for shop deletion cleanup)
      allow delete: if isAuth() && docInMyShopForDelete() && isOwner();
    }

    // ═══════════ 3.3.1 PRODUCT VARIANTS (Multi-industry) ═══════════
    match /product_variants/{variantId} {
      allow read: if isAuth() && docInMyShop();
      
      allow create: if isAuth() && 
                       isEmployee() &&
                       newDocInMyShop() &&
                       has(['productId', 'shopId']) &&
                       optNumGte0('costPrice') &&
                       optNumGte0('salePrice') &&
                       optNumGte0('quantity');
      
      allow update: if isAuth() && 
                       docInMyShop() &&
                       shopIdLocked() &&
                       optNumGte0('costPrice') &&
                       optNumGte0('salePrice') &&
                       optNumGte0('quantity');
      
      allow delete: if false;
    }

    // ═══════════ 3.3.2 STOCK ENTRIES (Phiếu nhập kho tạm) ═══════════
    match /stock_entries/{entryId} {
      // Cho phép đọc entries của shop mình
      allow read: if isAuth() && docInMyShop();
      
      // Tạo mới entry - cho phép employee trở lên
      // status phải là lowercase: draft, confirmed, cancelled
      allow create: if isAuth() && 
                       isEmployee() &&
                       newDocInMyShop() &&
                       has(['status', 'shopId', 'items']) &&
                       request.resource.data.status in ['draft', 'confirmed', 'cancelled', 'DRAFT', 'CONFIRMED', 'CANCELLED'];
      
      // Cập nhật - chỉ draft có thể sửa
      allow update: if isAuth() && 
                       docInMyShop() &&
                       shopIdLocked() &&
                       (resource.data.status in ['draft', 'DRAFT'] || isSuperAdmin());
      
      // Xóa - không cho xóa (soft delete via status = cancelled)
      allow delete: if false;
    }

    // ═══════════ 3.3b IMPORT ORDERS (Phiếu nhập kho) ═══════════
    match /import_orders/{orderId} {
      allow read: if isAuth() && docInMyShop();
      allow create: if isAuth() && isEmployee() && newDocInMyShop();
      allow update: if isAuth() && docInMyShop() && shopIdLocked();
      allow delete: if false;
    }

    match /import_order_items/{itemId} {
      allow read: if isAuth() && docInMyShop();
      allow create: if isAuth() && isEmployee() && newDocInMyShop();
      allow update: if isAuth() && docInMyShop() && shopIdLocked();
      allow delete: if false;
    }

    // ═══════════ 3.4 CUSTOMERS ═══════════
    match /customers/{customerId} {
      allow read: if isAuth() && docInMyShop();
      
      allow create: if isAuth() && 
                       newDocInMyShop() &&
                       has(['name', 'shopId']) &&
                       str('name', 1, 100);
      
      allow update: if isAuth() && 
                       docInMyShop() &&
                       shopIdLocked();
      
      allow delete: if false;
    }

    // ═══════════ 3.5 SALES RETURNS ═══════════
    match /sales_returns/{returnId} {
      allow read: if isAuth() && docInMyShop();
      
      allow create: if isAuth() && 
                       isEmployee() &&
                       newDocInMyShop();
      
      allow update: if isAuth() && 
                       docInMyShop() &&
                       shopIdLocked();
      
      allow delete: if isAuth() && docInMyShopForDelete() && isOwner();
    }

    // ═══════════ 3.6 SALES RETURN ITEMS ═══════════
    match /sales_return_items/{itemId} {
      allow read: if isAuth() && docInMyShop();
      
      allow create: if isAuth() && 
                       isEmployee() &&
                       newDocInMyShop();
      
      allow update: if isAuth() && 
                       docInMyShop() &&
                       shopIdLocked();
      
      allow delete: if isAuth() && docInMyShopForDelete() && isOwner();
    }

    // ┌──────────────────────────────────────────────────────────────────┐
    // │                   SECTION 4: FINANCE                             │
    // │      Collections: expenses, debts, debt_payments, cash_closings  │
    // │      Access: Manager+ only (sensitive financial data)            │
    // └──────────────────────────────────────────────────────────────────┘

    // ═══════════ 4.1 EXPENSES ═══════════
    match /expenses/{expenseId} {
      allow read: if isAuth() && docInMyShop() && isManager();
      
      allow create: if isAuth() && 
                       isManager() &&
                       newDocInMyShop() &&
                       has(['title', 'amount', 'category', 'date', 'shopId']) &&
                       str('title', 1, 200) &&
                       numGte0('amount');
      
      allow update: if isAuth() && 
                       docInMyShop() &&
                       isManager() &&
                       shopIdLocked() &&
                       numGte0('amount');
      
      // DELETE: Owner only (for shop deletion cleanup)
      allow delete: if isAuth() && docInMyShopForDelete() && isOwner();
    }

    // ═══════════ 4.2 DEBTS ═══════════
    // Note: Allow all authenticated shop members to create debts (for CÔNG NỢ payment)
    // This is needed when importing parts with payment method = CÔNG NỢ
    match /debts/{debtId} {
      allow read: if isAuth() && docInMyShop();
      
      allow create: if isAuth() && 
                       newDocInMyShop() &&
                       has(['personName', 'totalAmount', 'type', 'createdAt', 'shopId']) &&
                       numGte0('totalAmount') &&
                       optNumGte0('paidAmount');
      
      allow update: if isAuth() && 
                       docInMyShop() &&
                       shopIdLocked() &&
                       numGte0('totalAmount') &&
                       optNumGte0('paidAmount');
      
      // DELETE: Owner only (for shop deletion cleanup)
      allow delete: if isAuth() && docInMyShopForDelete() && isOwner();
    }

    // ═══════════ 4.3 DEBT_PAYMENTS ═══════════
    // Note: isEmployee() allows staff to record debt payments from customers
    match /debt_payments/{paymentId} {
      allow read: if isAuth() && docInMyShop() && isStaff();
      
      allow create: if isAuth() && 
                       isEmployee() &&
                       newDocInMyShop() &&
                       has(['amount', 'paidAt', 'shopId']) &&
                       numGte0('amount');
      
      allow update: if isAuth() && 
                       docInMyShop() &&
                       isStaff() &&
                       shopIdLocked() &&
                       numGte0('amount');
      
      // DELETE: Owner only (for shop deletion cleanup)
      allow delete: if isAuth() && docInMyShopForDelete() && isOwner();
    }

    // ═══════════ 4.4 CASH_CLOSINGS ═══════════
    match /cash_closings/{closingId} {
      allow read: if isAuth() && docInMyShop() && isManager();
      
      // FIX: Accept either 'date' or 'dateKey' field (app uses dateKey)
      allow create: if isAuth() && 
                       isManager() &&
                       newDocInMyShop() &&
                       (has(['shopId', 'date']) || has(['shopId', 'dateKey']));
      
      allow update: if isAuth() && 
                       docInMyShop() &&
                       isManager() &&
                       shopIdLocked();
      
      // DELETE: Owner only (for shop deletion cleanup)
      allow delete: if isAuth() && docInMyShopForDelete() && isOwner();
    }

    // ═══════════ 4.5 ADJUSTMENT_ENTRIES (điều chỉnh quỹ) ═══════════
    match /adjustment_entries/{entryId} {
      allow read: if isAuth() && docInMyShop() && isManager();
      
      allow create: if isAuth() && 
                       isManager() &&
                       newDocInMyShop() &&
                       has(['shopId', 'amount', 'type']);
      
      allow update: if isAuth() && 
                       docInMyShop() &&
                       isManager() &&
                       shopIdLocked();
      
      // DELETE: Owner only (for shop deletion cleanup)
      allow delete: if isAuth() && docInMyShopForDelete() && isOwner();
    }

    // ═══════════ 4.6 PAYMENT_INTENTS (yêu cầu thanh toán) ═══════════
    // Lưu trữ các giao dịch chờ thanh toán để đồng bộ giữa các máy
    match /payment_intents/{intentId} {
      allow read: if isAuth() && docInMyShop() && isStaff();
      
      allow create: if isAuth() && 
                       isEmployee() &&
                       newDocInMyShop() &&
                       has(['intentId', 'type', 'amount', 'shopId']) &&
                       numGte0('amount');
      
      allow update: if isAuth() && 
                       docInMyShop() &&
                       isStaff() &&
                       shopIdLocked();
      
      allow delete: if false;
    }

    // ┌──────────────────────────────────────────────────────────────────┐
    // │                   SECTION 5: SUPPLIERS                           │
    // │   Collections: suppliers, supplier_payments, purchase_orders,    │
    // │                supplier_import_history, supplier_product_prices  │
    // └──────────────────────────────────────────────────────────────────┘

    // ═══════════ 5.1 SUPPLIERS ═══════════
    match /suppliers/{supplierId} {
      allow read: if isAuth() && docInMyShop();
      
      allow create: if isAuth() && 
                       isEmployee() &&
                       newDocInMyShop() &&
                       has(['name', 'shopId']) &&
                       str('name', 1, 200);
      
      allow update: if isAuth() && 
                       docInMyShop() &&
                       shopIdLocked();
      
      // DELETE: Owner only (for shop deletion cleanup)
      allow delete: if isAuth() && docInMyShopForDelete() && isOwner();
    }

    // ═══════════ 5.2 SUPPLIER_PAYMENTS ═══════════
    match /supplier_payments/{paymentId} {
      allow read: if isAuth() && docInMyShop() && isManager();
      
      allow create: if isAuth() && 
                       isManager() &&
                       newDocInMyShop() &&
                       has(['supplierId', 'amount', 'paidAt', 'shopId']) &&
                       numGte0('amount');
      
      allow update: if isAuth() && 
                       docInMyShop() &&
                       isManager() &&
                       shopIdLocked() &&
                       numGte0('amount');
      
      // DELETE: Owner only (for shop deletion cleanup)
      allow delete: if isAuth() && docInMyShopForDelete() && isOwner();
    }

    // ═══════════ 5.3 PURCHASE_ORDERS ═══════════
    match /purchase_orders/{orderId} {
      allow read: if isAuth() && docInMyShop() && isManager();
      
      allow create: if isAuth() && 
                       isManager() &&
                       newDocInMyShop() &&
                       has(['shopId']);
      
      allow update: if isAuth() && 
                       docInMyShop() &&
                       isManager() &&
                       shopIdLocked();
      
      allow delete: if false;
    }

    // ═══════════ 5.4 SUPPLIER_IMPORT_HISTORY ═══════════
    match /supplier_import_history/{historyId} {
      allow read: if isAuth() && docInMyShop();
      
      allow create: if isAuth() && 
                       isEmployee() &&
                       newDocInMyShop() &&
                       has(['supplierId', 'shopId']);
      
      allow update: if isAuth() && 
                       docInMyShop() &&
                       shopIdLocked();
      
      allow delete: if false;
    }

    // ═══════════ 5.5 SUPPLIER_PRODUCT_PRICES ═══════════
    match /supplier_product_prices/{priceId} {
      allow read: if isAuth() && docInMyShop();
      
      allow create: if isAuth() && 
                       isEmployee() &&
                       newDocInMyShop() &&
                       has(['supplierId', 'productName', 'price', 'shopId']) &&
                       numGte0('price');
      
      allow update: if isAuth() && 
                       docInMyShop() &&
                       shopIdLocked() &&
                       numGte0('price');
      
      allow delete: if isAuth() && docInMyShopForDelete() && isManager();
    }

    // ┌──────────────────────────────────────────────────────────────────┐
    // │                   SECTION 6: REPAIR PARTNERS                     │
    // │   Collections: repair_partners, repair_partner_payments,         │
    // │                partner_repair_history                            │
    // └──────────────────────────────────────────────────────────────────┘

    // ═══════════ 6.1 REPAIR_PARTNERS ═══════════
    match /repair_partners/{partnerId} {
      allow read: if isAuth() && docInMyShop();
      
      allow create: if isAuth() && 
                       isEmployee() &&
                       newDocInMyShop() &&
                       has(['name', 'shopId']) &&
                       str('name', 1, 200);
      
      allow update: if isAuth() && 
                       docInMyShop() &&
                       shopIdLocked();
      
      allow delete: if false;
    }

    // ═══════════ 6.2 REPAIR_PARTNER_PAYMENTS ═══════════
    match /repair_partner_payments/{paymentId} {
      allow read: if isAuth() && docInMyShop() && isManager();
      
      allow create: if isAuth() && 
                       isManager() &&
                       newDocInMyShop() &&
                       has(['partnerId', 'amount', 'paidAt', 'shopId']) &&
                       numGte0('amount');
      
      allow update: if isAuth() && 
                       docInMyShop() &&
                       isManager() &&
                       shopIdLocked() &&
                       numGte0('amount');
      
      allow delete: if false;
    }

    // ═══════════ 6.3 PARTNER_REPAIR_HISTORY ═══════════
    match /partner_repair_history/{historyId} {
      allow read: if isAuth() && docInMyShop();
      
      allow create: if isAuth() && 
                       isEmployee() &&
                       newDocInMyShop() &&
                       has(['partnerId', 'repairOrderId', 'shopId']);
      
      allow update: if isAuth() && 
                       docInMyShop() &&
                       shopIdLocked();
      
      allow delete: if false;
    }

    // ┌──────────────────────────────────────────────────────────────────┐
    // │                   SECTION 7: HR & ATTENDANCE                     │
    // │                   Collection: attendance, work_schedules         │
    // └──────────────────────────────────────────────────────────────────┘

    // ═══════════ 7.1 ATTENDANCE ═══════════
    match /attendance/{attendanceId} {
      // READ: Own records OR manager sees all
      allow read: if isAuth() && 
                     docInMyShop() &&
                     (isManager() || resource.data.userId == uid());
      
      // CREATE: Own attendance OR manager can create for anyone
      allow create: if isAuth() && 
                       newDocInMyShop() &&
                       has(['userId', 'dateKey', 'createdAt', 'shopId']) &&
                       (isManager() || request.resource.data.userId == uid());
      
      // UPDATE: Manager full access, employee limited (no status/locked/approval changes)
      allow update: if isAuth() && 
                       docInMyShop() &&
                       shopIdLocked() &&
                       (isManager() || 
                        (resource.data.userId == uid() &&
                         !changed('status') && 
                         !changed('locked') && 
                         !changed('approvedBy')));
      
      allow delete: if false;
    }

          // ═══════════ 7.1b LEAVE_REQUESTS ═══════════
          match /leave_requests/{requestId} {
            // READ: Own requests OR manager sees all requests in shop
            allow read: if isAuth() &&
                           docInMyShop() &&
                           (isManager() || resource.data.userId == uid());

            // CREATE: Employee can only create own request
            allow create: if isAuth() &&
                             newDocInMyShop() &&
                             has(['userId', 'leaveType', 'startDate', 'endDate', 'createdAt', 'shopId']) &&
                             request.resource.data.userId == uid();

            // UPDATE: Manager can approve/reject, employee can edit own request before approval
            allow update: if isAuth() &&
                             docInMyShop() &&
                             shopIdLocked() &&
                             (isManager() ||
                              (resource.data.userId == uid() &&
                               resource.data.status == 'pending' &&
                               !changed('status') &&
                               !changed('approvedBy') &&
                               !changed('approvedAt') &&
                               !changed('rejectReason')));

            allow delete: if false;
          }

          // ═══════════ 7.1c SHIFT_SWAP_REQUESTS ═══════════
          match /shift_swap_requests/{requestId} {
            // READ: requester sees own, manager sees all in shop, target user can read assigned swaps
            allow read: if isAuth() &&
                           docInMyShop() &&
                           (isManager() ||
                            resource.data.requesterId == uid() ||
                            (resource.data.targetUserId != null && resource.data.targetUserId == uid()));

            // CREATE: employee/staff can create own request in own shop
            allow create: if isAuth() &&
                             newDocInMyShop() &&
                             has(['requesterId', 'requestedDate', 'currentShift', 'desiredShift', 'status', 'createdAt', 'updatedAt', 'shopId']) &&
                             request.resource.data.requesterId == uid();

            // UPDATE:
            // - Manager: approve/reject or adjust request
            // - Requester: only allowed to cancel pending request
            allow update: if isAuth() &&
                             docInMyShop() &&
                             shopIdLocked() &&
                             (isManager() ||
                              (resource.data.requesterId == uid() &&
                               resource.data.status == 'pending' &&
                               request.resource.data.status in ['pending', 'cancelled'] &&
                               !changed('reviewedBy') &&
                               !changed('reviewedByName') &&
                               !changed('reviewedAt')));

            allow delete: if false;
          }

    // ═══════════ 7.2 WORK_SCHEDULES ═══════════
    // Stores work schedule settings (general shop settings and per-staff schedules)
    // Document IDs: "shop_general_{shopId}" for general, "staff_{userId}_{shopId}" for staff
    match /work_schedules/{scheduleId} {
      // READ: Any authenticated user in the shop
      allow read: if isAuth() && 
                     (isSuperAdmin() || 
                      resource.data.shopId == myShopId());
      
      // CREATE: Owner/Manager can create schedules for their shop
      allow create: if isAuth() && 
                       newDocInMyShop() &&
                       isManager();
      
      // UPDATE: Owner/Manager can update schedules
      allow update: if isAuth() && 
                       docInMyShop() &&
                       shopIdLocked() &&
                       isManager();
      
      allow delete: if isOwner();
    }

    // ┌──────────────────────────────────────────────────────────────────┐
    // │                   SECTION 8: CHAT & MESSAGING                    │
    // │              Collections: chats, chat_messages                   │
    // │              Real-time collaboration features                    │
    // └──────────────────────────────────────────────────────────────────┘

    // ═══════════ 8.1 CHATS ═══════════
    match /chats/{chatId} {
      allow read: if isAuth() && docInMyShop();
      
      // CREATE: Must be sender, must have message
      allow create: if isAuth() && 
                       newDocInMyShop() &&
                       has(['message', 'senderId', 'shopId']) &&
                       request.resource.data.senderId == uid();
      
      // UPDATE: Shop members can update (for read receipts, etc.)
      allow update: if isAuth() && docInMyShop();
      
      allow delete: if false;
    }

    // ═══════════ 8.2 CHAT_MESSAGES ═══════════
    match /chat_messages/{messageId} {
      allow read: if isAuth() && docInMyShop();
      
      allow create: if isAuth() && 
                       newDocInMyShop() &&
                       has(['message', 'senderId', 'shopId']);
      
      allow update: if isAuth() && docInMyShop();
      
      allow delete: if false;
    }

    // ═══════════ 8.3 CHAT_ONLINE (presence) ═══════════
    match /chat_online/{onlineId} {
      allow read: if isAuth();
      
      // CREATE/UPDATE: User can set their own online status
      allow create, update: if isAuth() && 
                               onlineId.matches('.*' + uid() + '.*');
      
      // DELETE: Own record only
      allow delete: if isAuth() && onlineId.matches('.*' + uid() + '.*');
    }

    // ═══════════ 8.4 CHAT_TYPING (presence) ═══════════
    match /chat_typing/{typingId} {
      allow read: if isAuth();
      
      // CREATE/UPDATE: User can set their own typing status  
      allow create, update: if isAuth() && 
                               typingId.matches('.*' + uid() + '.*');
      
      // DELETE: Own record only
      allow delete: if isAuth() && typingId.matches('.*' + uid() + '.*');
    }

    // ┌──────────────────────────────────────────────────────────────────┐
    // │              SECTION 8.5: PAYMENT REQUESTS                       │
    // │           Collection: payment_requests                           │
    // │           Chat-like payment collection requests                  │
    // └──────────────────────────────────────────────────────────────────┘

    match /payment_requests/{requestId} {
      allow read: if isAuth() && docInMyShop();

      allow create: if isAuth() &&
                       newDocInMyShop() &&
                       has(['customerName', 'customerPhone', 'amount', 'senderId', 'shopId']) &&
                       request.resource.data.senderId == uid();

      allow update: if isAuth() && docInMyShop();

      allow delete: if false;
    }

    // ┌──────────────────────────────────────────────────────────────────┐
    // │                   SECTION 9: NOTIFICATIONS                       │
    // │           Collections: notifications, shop_notifications         │
    // │           User personal + shop-wide broadcasts                   │
    // └──────────────────────────────────────────────────────────────────┘

    // ═══════════ 9.1 NOTIFICATIONS (personal) ═══════════
    match /notifications/{notificationId} {
      // READ: Shop-wide OR own notifications OR broadcast (userId=null)
      allow read: if isAuth() && 
                     (docInMyShop() || 
                      resource.data.userId == uid() ||
                      resource.data.userId == null);
      
      allow create: if isAuth() && newDocInMyShop();
      
      // UPDATE: Mark as read
      allow update: if isAuth() && 
                       (docInMyShop() || resource.data.userId == uid());
      
      allow delete: if false;
    }

    // ═══════════ 9.2 SHOP_NOTIFICATIONS (broadcast) ═══════════
    match /shop_notifications/{notificationId} {
      allow read: if isAuth() && docInMyShop();
      
      allow create: if isAuth() && newDocInMyShop();
      
      allow update: if isAuth() && docInMyShop();
      
      // DELETE: Manager+ can clear old notifications
      allow delete: if isAuth() && docInMyShopForDelete() && isManager();
    }

    // ┌──────────────────────────────────────────────────────────────────┐
    // │                   SECTION 10: SYSTEM DATA                        │
    // │     Collections: audit_logs, quick_input_codes, repair_parts     │
    // │     audit_logs: IMMUTABLE (write-once)                           │
    // └──────────────────────────────────────────────────────────────────┘

    // ═══════════ 10.1 AUDIT_LOGS (IMMUTABLE) ═══════════
    // Critical: Once written, cannot be modified or deleted
    match /audit_logs/{logId} {
      // READ: Manager+ only
      allow read: if isAuth() && docInMyShop() && isManager();
      
      // CREATE: Any authenticated shop member
      allow create: if isAuth() && 
                       newDocInMyShop() &&
                       has(['action', 'userId', 'createdAt', 'shopId']);
      
      // UPDATE: NEVER - audit logs are immutable
      allow update: if false;
      
      // DELETE: NEVER - audit logs are immutable
      allow delete: if false;
    }

    // ═══════════ 10.2 QUICK_INPUT_CODES ═══════════
    match /quick_input_codes/{codeId} {
      allow read: if isAuth() && docInMyShop();
      
      allow create: if isAuth() && 
                       newDocInMyShop() &&
                       has(['code', 'shopId']);
      
      allow update: if isAuth() && 
                       docInMyShop() &&
                       shopIdLocked();
      
      // DELETE: Allowed for cleanup
      allow delete: if isAuth() && docInMyShopForDelete();
    }

    // ═══════════ 10.3 REPAIR_PARTS ═══════════
    // Note: partName is the field name used by the app (not 'name')
    match /repair_parts/{partId} {
      allow read: if isAuth() && docInMyShop();
      
      allow create: if isAuth() && 
                       isEmployee() &&
                       newDocInMyShop() &&
                       has(['partName', 'shopId']) &&
                       str('partName', 1, 200);
      
      allow update: if isAuth() && 
                       docInMyShop() &&
                       shopIdLocked();
      
      allow delete: if false;
    }

    // ═══════════ 10.4 FINANCIAL_ACTIVITIES (Stock entry confirm) ═══════════
    // Used by confirmEntry() when confirming stock entries
    match /financial_activities/{activityId} {
      allow read: if isAuth() && docInMyShop() && isManager();
      
      allow create: if isAuth() && 
                       isEmployee() &&
                       newDocInMyShop() &&
                       has(['type', 'amount', 'shopId']);
      
      allow update: if isAuth() && 
                       docInMyShop() &&
                       isManager() &&
                       shopIdLocked();
      
      allow delete: if false;
    }

    // ═══════════ 10.4b FINANCIAL_ACTIVITY_LOG (Sales return refund, etc.) ═══════════
    match /financial_activity_log/{logId} {
      allow read: if isAuth() && docInMyShop();

      allow create: if isAuth() &&
                       isEmployee() &&
                       newDocInMyShop() &&
                       has(['activityType', 'amount', 'shopId']);

      allow update: if isAuth() &&
                       docInMyShop() &&
                       shopIdLocked();

      allow delete: if false;
    }

    // ═══════════ 10.5 SUPPLIER_DEBTS (Stock entry confirm with CÔNG NỢ) ═══════════
    // Used by confirmEntry() when payment method is CÔNG NỢ
    match /supplier_debts/{debtId} {
      allow read: if isAuth() && docInMyShop();
      
      allow create: if isAuth() && 
                       isEmployee() &&
                       newDocInMyShop() &&
                       has(['supplierId', 'amount', 'shopId']);
      
      allow update: if isAuth() && 
                       docInMyShop() &&
                       shopIdLocked();
      
      allow delete: if false;
    }

    // ┌──────────────────────────────────────────────────────────────────┐
    // │                   SECTION 11: HR & SALARY SETTINGS               │
    // │     Collections: shop_deduction_settings, employee_salary_settings│
    // │                  shop_salary_defaults                            │
    // └──────────────────────────────────────────────────────────────────┘

    // ═══════════ 11.1 SHOP_DEDUCTION_SETTINGS ═══════════
    // Stores shop-level salary deduction, insurance, and tax settings
    // Document ID is shopId — per-shop isolation via doc path
    match /shop_deduction_settings/{shopId} {
      allow read, create, update: if isAuth() && belongsTo(shopId);
      allow delete: if false;
    }

    // ═══════════ 11.2 EMPLOYEE_SALARY_SETTINGS ═══════════
    // Stores per-employee salary settings (base salary, allowances, etc.)
    // Requires shopId field for multi-tenant isolation
    match /employee_salary_settings/{settingId} {
      // READ: Manager+ in same shop (managers need to view salary info)
      allow read: if isAuth() && docInMyShop() && isManager();
      
      // CREATE: Manager+ can add salary settings for employees in their shop
      allow create: if isAuth() && newDocInMyShop() && isManager();
      
      // UPDATE: Manager+ can update salary settings
      allow update: if isAuth() && docInMyShop() && isManager() && shopIdLocked();
      
      // DELETE: Owner only (sensitive data)
      allow delete: if isAuth() && docInMyShopForDelete() && isOwner();
    }

    // ═══════════ 11.3 SHOP_SALARY_DEFAULTS ═══════════
    // Stores shop-level default salary settings (working hours, overtime rate, etc.)
    // Document ID is shopId for easy lookup
    match /shop_salary_defaults/{shopId} {
      // READ: Manager+ in same shop (managers need to view salary defaults)
      allow read: if isAuth() && belongsTo(shopId) && isManager();
      
      // CREATE/UPDATE: Owner only (shop-wide settings)
      allow create, update: if isAuth() && belongsTo(shopId) && isOwner();
      
      // DELETE: Not allowed - settings should persist
      allow delete: if false;
    }

    // ┌──────────────────────────────────────────────────────────────────┐
    // │                   SECTION 12: SUPER ADMIN SECURITY               │
    // │     Collections: admin_security, admin_audit_log                 │
    // │     admin_security: PIN hash storage (super admin only)          │
    // │     admin_audit_log: Immutable login/action audit trail          │
    // └──────────────────────────────────────────────────────────────────┘

    // ═══════════ 12.1 ADMIN_SECURITY (super admin PIN & settings) ═══════════
    match /admin_security/{docId} {
      // Only super admin can read/write their own security doc
      allow read: if isSuperAdmin() && uid() == docId;
      allow create, update: if isSuperAdmin() && uid() == docId;
      allow delete: if false;
    }

    // ═══════════ 12.2 ADMIN_AUDIT_LOG (immutable audit trail) ═══════════
    match /admin_audit_log/{logId} {
      // Only super admin can read audit logs
      allow read: if isSuperAdmin();
      // Only super admin can create (write-once)
      allow create: if isSuperAdmin() &&
                       has(['uid', 'action', 'timestamp']);
      // Immutable: no update or delete
      allow update: if false;
      allow delete: if false;
    }

    // ┌──────────────────────────────────────────────────────────────────┐
    // │                   SECTION 13: CATCH-ALL DENY                     │
    // │         CRITICAL: Any undefined collection is DENIED             │
    // └──────────────────────────────────────────────────────────────────┘
    
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
